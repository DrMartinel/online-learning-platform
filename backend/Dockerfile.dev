FROM node:20-bookworm-slim
WORKDIR /app

# Install deps in image (cached), source will be bind-mounted in dev.
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

ENV NODE_ENV=development
ENV PORT=3001
# tsc can approach 4GB+ with declaration emit + large dependency types; align with package.json build
ENV NODE_OPTIONS=--max-old-space-size=8192

EXPOSE 3001
CMD ["sh", "-lc", "npm run build && npm run dev"]

